# This file documents local-only configuration values.
# Copy to ".env" and adjust paths/models for your machine.

# Ollama model used for all LLM calls in this project.
OLLAMA_MODEL=llama3.2:latest

# Whisper model size (tiny/base/small/medium/large).
WHISPER_MODEL=base

# Optional: where to load supplemental RAG context files from.
CONTEXT_DIR=./context

# Optional: microphone sample rate for recording voice answers.
AUDIO_SAMPLE_RATE=16000

# Optional: directory to save temporary recordings.
RECORDINGS_DIR=./voice_recordings

# Optional Piper voice model path for TTS output.
PIPER_MODEL_PATH=
